import pandas as pd
import numpy as np
import statsmodels.api as sm
import os

from src.utils import normalize_weights compute_returns

def compute_signal(index_level, weights, predicted_returns):
    weights = normalize_weights(weights)
    return index_level * (weights * predicted_returns).sum()

def estimate_feedback(dX, h, X_lag):
    Y = np.array(dX) - np.array(h)
    X = sm.add_constant(X_lag)
    model = sm.OLS(Y, X).fit()
    slope = model.params[1]
    intercept = model.params[0]
    kappa = -slope
    mu = intercept / kappa
    return kappa, mu, model

def predict_next_move(h, kappa, mu, X_last):
    return h - kappa * (X_last - mu)

def run_model(csv_path, output_path='output/predictions.csv'):
    # Load data
    data = pd.read_csv(csv_path, sep='|')
    data.columns = data.columns.str.strip()  # remove hidden spaces
    index_levels = data['Index'].values

    # Dynamically detect columns
    return_cols = [c for c in data.columns if '_Return' in c]
    weight_cols = [c for c in data.columns if '_Weight' in c]

    returns = data[return_cols].values
    weights = data[weight_cols].values

    # Compute daily dX
    dX = np.diff(index_levels)

    # Compute signal h
    h = []
    for i in range(1, len(index_levels)):
        h_i = compute_signal(index_levels[i-1], weights[i-1], returns[i-1])
        h.append(h_i)
    h = np.array(h)

    # Estimate feedback
    X_lag = index_levels[:-1]
    kappa, mu, model = estimate_feedback(dX, h, X_lag)
    print(f"Kappa: {kappa:.5f}, Mu: {mu:.2f}")
    print(model.summary())

    # Predict next day
    X_last = index_levels[-1]
    h_last = compute_signal(X_last, weights[-1], returns[-1])
    dX_pred = predict_next_move(h_last, kappa, mu, X_last)
    print(f"Predicted next-day index change: {dX_pred:.2f}")

    # Save outputs
    output = pd.DataFrame({
        'Date': data['Date'].values[1:],
        'dX': dX,
        'Signal_h': h
    })
    # ensure output folder exists
    os.makedirs(os.path.dirname(output_path), exist_ok=True)
    output.to_csv(output_path, index=False)
    print(f"Saved predictions to {output_path}")