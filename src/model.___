# model.py

import pandas as pd
import statsmodels.api as sm

def compute_signal(csv_path, ar_weight=0.5, weight_signal_weight=0.5):
    """
    Predict next-day index return using a combination of:
    1. AR(1) model on index returns
    2. Weighted sum of stock returns

    Parameters:
        csv_path: path to CSV with index, stock returns, and stock weights
        ar_weight: weight of AR(1) prediction in final signal
        weight_signal_weight: weight of weighted-stock signal in final signal
    """

    # 1️⃣ Load CSV
    df = pd.read_csv(csv_path, sep='|')
    df.columns = df.columns.str.strip()  # remove hidden spaces
    df["Date"] = pd.to_datetime(df["Date"], dayfirst=True)
    df = df.sort_values("Date")

    # 2️⃣ Compute index returns
    df["Index_Return"] = df["Index"].pct_change()
    df = df.dropna()

    # 3️⃣ --- AR(1) Prediction ---
    df["Lag_Return"] = df["Index_Return"].shift(1)
    ar_df = df.dropna()  # drop first row after shift

    X_ar = sm.add_constant(ar_df["Lag_Return"])
    y_ar = ar_df["Index_Return"]

    model_ar = sm.OLS(y_ar, X_ar).fit()

    last_lag = ar_df["Lag_Return"].iloc[-1]
    predicted_return_ar = model_ar.predict([1, last_lag])[0]

    # --- Weighted stock signal ---
    # Lowercase matching for robustness
    stock_return_cols = [col for col in df.columns if "_return" in col.lower()]
    stock_weight_cols = [col for col in df.columns if "_weight" in col.lower()]

    print(df.columns.tolist())               # see all column names
    print(df[stock_return_cols].iloc[-1])   # latest returns
    print(df[stock_weight_cols].iloc[-1])   # latest weights        

    latest_returns = df[stock_return_cols].iloc[-1]
    latest_weights = df[stock_weight_cols].iloc[-1] / 100  # convert % to fraction

    predicted_return_weighted = (latest_returns * latest_weights).sum()

    # 5️⃣ --- Combine signals ---
    predicted_return = (
        ar_weight * predicted_return_ar +
        weight_signal_weight * predicted_return_weighted
    )

    # 6️⃣ Predict next index price
    last_price = df["Index"].iloc[-1]
    predicted_price = last_price * (1 + predicted_return)

    return {
        "predicted_return": predicted_return,
        "predicted_price": predicted_price,
        "ar_prediction": predicted_return_ar,
        "weighted_prediction": predicted_return_weighted,
        "ar_model": model_ar
    }