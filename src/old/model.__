# model.py (rolling window version)

from turtle import down, up, up

import pandas as pd
import statsmodels.api as sm

def compute_signal(csv_path, ar_weight=0.4, weight_signal_weight=0.6, rolling_window=20):
    """
    Predict next-day index return using:
    1. Rolling-window AR(1) on index returns
    2. Rolling-window weighted sum of stock returns
    Automatically converts stock returns from percent to decimal.
    """

    # 1️⃣ Load CSV
    df = pd.read_csv(csv_path, sep=',')
    df.columns = df.columns.str.strip()  # remove spaces
    df["Date"] = pd.to_datetime(df["Date"], dayfirst=False)
    df = df.sort_values("Date").reset_index(drop=True)

    # print(df.tail(20))
    # print("Last date:", df["Date"].max())

    # Index returns
    df["Index_Return"] = df["Index"].pct_change()
    df = df.dropna(subset=["Index_Return"])

    # --- AR(1) signal using rolling window ---
    df["Lag2_Return"] = df["Index_Return"].shift(2)
    df["Lag_Return"] = df["Index_Return"].shift(1)
    ar_df = df.dropna(subset=["Lag_Return"])

    # Take last `rolling_window` rows for smoothing
    ar_df_rolling = ar_df.tail(rolling_window)

    X_ar = sm.add_constant(ar_df_rolling[["Lag_Return","Lag2_Return"]])
    y_ar = ar_df_rolling["Index_Return"]
    model_ar = sm.OLS(y_ar, X_ar).fit()
    last_lag1 = ar_df_rolling["Lag_Return"].iloc[-1]
    last_lag2 = ar_df_rolling["Lag2_Return"].iloc[-1]

    predicted_return_ar = model_ar.predict([1, last_lag1, last_lag2])[0]

    # --- Weighted stock signal using rolling window ---
    stock_return_cols = [
        col for col in df.columns
        if col.endswith("_Return") and col not in ["Index_Return","Lag_Return","Lag2_Return"]
    ]
    
    # print("Stock return columns:", stock_return_cols)

    up = 0
    down = 0

    for col in stock_return_cols:
        last_ret = df[col].iloc[-1]

        if last_ret > 0:
            up += 1
        elif last_ret < 0:
            down += 1

    breadth = (up - down) / (up + down)

    breadth_signal = breadth * 0.002

    predicted_return_weighted = 0
    for ret_col in stock_return_cols:
        weight_col = ret_col.replace("_Return", "_Weight")
        # rolling average of stock returns
        recent = df[ret_col].iloc[-1] / 100
        avg = df[ret_col].iloc[-rolling_window:].mean() / 100

        signal = 0.7 * recent + 0.3 * avg
        w = df[weight_col].iloc[-1] / 100  # latest weight
        predicted_return_weighted += signal * w

    predicted_return_weighted = max(min(predicted_return_weighted, 0.01), -0.01)
    ar_vol = abs(predicted_return_ar)
    stock_vol = abs(predicted_return_weighted)

    total = ar_vol + stock_vol

    if total == 0:
        ar_weight = 0.4
        stock_weight = 0.6
    else:
        ar_weight = ar_vol / total
        stock_weight = stock_vol / total

    # --- Combine signals ---
    
    
    predicted_return = (
    ar_weight * predicted_return_ar +
    stock_weight * predicted_return_weighted +
    0.2 * breadth_signal
    )

    if abs(predicted_return) < 0.0003:
        predicted_return = 0

    # --- Predict next index price ---
    last_price = df["Index"].iloc[-1]
    predicted_price = last_price * (1 + predicted_return)

    return {
        "predicted_return": predicted_return,
        "predicted_price": predicted_price,
        "ar_prediction": predicted_return_ar,
        "weighted_prediction": predicted_return_weighted,
        "ar_model": model_ar
    }